{
  "grammars": [
    {
      "name": "virdant",
      "camelcase": "Virdant",
      "scope": "source.virdant",
      "path": ".",
      "file-types": [
        "vir"
      ],
      "highlights": "queries/highlights.scm",
      "injection-regex": "vir"
    }
  ],
  "metadata": {
    "version": "0.0.1",
    "license": "MIT",
    "description": "Virdant grammar for tree-sitter",
    "links": {
      "repository": "https://github.com/tree-sitter/tree-sitter-virdant"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
